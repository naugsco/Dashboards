# ══════════════════════════════════════════════════════════════════
# Pulse Dashboard — Backend Environment Variables
#
# Copy this file to the backend directory and fill in real values:
#   cp deploy/backend.env.example backend/.env
#   nano backend/.env
# ══════════════════════════════════════════════════════════════════

# ── MongoDB ─────────────────────────────────────────────────────────────────
# Free tier available at: https://cloud.mongodb.com
# Steps: Sign up → Create cluster (choose M0 Free) → Connect →
#        "Connect your application" → copy connection string
#
MONGO_URL=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?appName=YOUR_APP
DB_NAME=pulse_dashboard

# ── NewsAPI.org ──────────────────────────────────────────────────────────────
# Free tier: 100 requests/day (dashboard fetches every 15 min = ~96/day)
# Sign up at: https://newsapi.org → copy API key from dashboard
#
NEWS_API_KEY=your_newsapi_key_here

# ── CORS ─────────────────────────────────────────────────────────────────────
# Leave as * for now. Once you have a domain you can restrict it:
#   CORS_ORIGINS=https://enadashboard.online
#
CORS_ORIGINS=*
